        "html_custom": "<!-- ===== FAIXA CONTAGEM REGRESSIVA ===== -->\n  <!-- CONFIGURAÇÕES: edite as 3 linhas abaixo -->\n  <div id=\"countdown-banner\" data-hours=\"6\" data-minutes=\"00\" data-seconds=\"00\">\n    <!-- TEXTO: edite aqui -->\n    <span class=\"banner-text\">🔥 LANÇAMENTO COPOS TÉRMICOS 🔥\n\tOferta Exclusiva de Lançamento! </span>\n    <span class=\"banner-timer\" id=\"countdown-timer\">05:40:35</span>\n  </div>\n\n  <style>\n    #countdown-banner {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      width: 100vw;\n      margin-left: calc(-50vw + 50%);\n      padding: 18px 20px 22px;\n      background: #000000;\n      color: #ffffff;\n      font-family: Arial, Helvetica, sans-serif;\n      text-align: center;\n      box-sizing: border-box;\n    }\n    .banner-text {\n      font-weight: 600;\n      font-size: 3rem;\n      text-transform: uppercase;\n      letter-spacing: 1px;\n    }\n    .banner-timer {\n      font-weight: 700;\n      font-size: 42px;\n      font-variant-numeric: tabular-nums;\n      letter-spacing: 6px;\n    }\n    @media (max-width: 600px) {\n      .banner-text {\n        font-size: 14px;\n      }\n      .banner-timer {\n        font-size: 32px;\n        letter-spacing: 4px;\n      }\n    }\n  </style>\n\n  <script>\n  (function() {\n    var banner = document.getElementById('countdown-banner');\n    var timerEl = document.getElementById('countdown-timer');\n    var STORAGE_KEY = 'countdown_banner_expires';\n\n    var h = parseInt(banner.getAttribute('data-hours')) || 0;\n    var m = parseInt(banner.getAttribute('data-minutes')) || 0;\n    var s = parseInt(banner.getAttribute('data-seconds')) || 0;\n    var durationMs = (h * 3600 + m * 60 + s) * 1000;\n\n    // Busca ou cria o horário de expiração\n    var expiresAt = localStorage.getItem(STORAGE_KEY);\n    if (!expiresAt) {\n      expiresAt = Date.now() + durationMs;\n      localStorage.setItem(STORAGE_KEY, expiresAt);\n    } else {\n      expiresAt = parseInt(expiresAt);\n    }\n\n    function pad(n) { return n < 10 ? '0' + n : n; }\n\n    function update() {\n      var remaining = Math.floor((expiresAt - Date.now()) / 1000);\n\n      if (remaining <= 0) {\n        timerEl.textContent = '00:00:00';\n        localStorage.removeItem(STORAGE_KEY);\n        return;\n      }\n\n      var hh = Math.floor(remaining / 3600);\n      var mm = Math.floor((remaining % 3600) / 60);\n      var ss = remaining % 60;\n      timerEl.textContent = pad(hh) + ':' + pad(mm) + ':' + pad(ss);\n      setTimeout(update, 1000);\n    }\n\n    update();\n  })();\n  </script>\n  <!-- ===== FIM DA FAIXA ===== -->",
